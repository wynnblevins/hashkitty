#!/usr/bin/env python3

import os
import subprocess
import sys
import time

# -----------------------------
# Logging
# -----------------------------
def log(msg, level="INFO"):
    print(f"[{time.strftime('%H:%M:%S')}] [{level}] {msg}")


def print_usage():
    print("""
====================================================
                HASHKITTY - HELP
====================================================

Usage:
  ./hashkitty <mode> [options]

----------------------------------------------------
ATTACK MODES
----------------------------------------------------

[1] WORDLIST
  wordlist <wordlist_file>

  Runs a dictionary attack using the provided wordlist.

  Example:
    ./hashkitty wordlist rockyou.txt


[2] MASK (BRUTE FORCE)
  mask <mask>

  Runs a pure brute-force attack using a mask.

  Common masks:
    ?d = digit (0-9)
    ?l = lowercase (a-z)
    ?u = uppercase (A-Z)
    ?a = all printable characters

  Examples:
    ./hashkitty mask ?d?d?d?d?d?d?d?d
    ./hashkitty mask ?l?l?l?l?d?d


[3] HYBRID (WORD + MASK)
  hybrid <wordlist_file> <mask>

  Appends the mask to each word in the wordlist.

  Example:
    hashkitty hybrid rockyou.txt ?d?d

  This will try:
    password00
    password01
    ...
    password99


[4] HYBRID REVERSE (MASK + WORD)
  hybrid_reverse <wordlist_file> <mask>

  Prepends the mask to each word in the wordlist.

  Example:
    ./hashkitty hybrid_reverse rockyou.txt ?d?d

  This will try:
    00password
    01password
    ...
    99password


[5] RESTORE
  restore <session_name>

  Resumes a named hashcat session.

  Example:

    ./hashkitty restore hashkitty_wordlist_rockyou_txt

----------------------------------------------------
IMPORTANT CONCEPTS
----------------------------------------------------

• Hybrid attacks MULTIPLY keyspace:
    total = wordlist_size × mask_combinations

• DO NOT use large masks with hybrid:
    BAD:  ?a?a?a?a?a?a?d?d   (too large)
    GOOD: ?d?d or ?d?d?d

• If you want brute force, use MASK mode instead.


----------------------------------------------------
