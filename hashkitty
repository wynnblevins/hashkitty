""")


# -----------------------------
# Banner Output
# -----------------------------
def print_banner(message, success=True):
    GREEN = "\033[92m"
    RED = "\033[91m"
    RESET = "\033[0m"

    color = GREEN if success else RED
    border_char = "=" if success else "!"

    border = border_char * (len(message) + 10)

    print("\n" + color + border)
    print(f"   {message}")
    print(border + RESET + "\n")


# -----------------------------
# Run Interactive Command
# -----------------------------
def run_interactive_command(cmd):
    result = subprocess.run(cmd)
    return result.returncode

# -----------------------------
# Run Command
# -----------------------------
def run_command(cmd):
    try:
        return subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=True
        )

    except subprocess.CalledProcessError as e:
        log(f"Command failed: {' '.join(cmd)}", "ERROR")
        return e

    except Exception as e:
        log(f"Command failed: {e}", "ERROR")
        return None

# -----------------------------
# Convert PCAP → 22000
# -----------------------------
def convert_to_hash(pcap):
    hash_file = f"{pcap}.22000"

    result = run_command([
        "hcxpcapngtool",
        "-o", hash_file,
        pcap
    ])

    if result is None:
        return None

    output = (result.stdout + result.stderr).lower()

    if "no hashes written" in output:
        log(f"Skipping (no usable handshake): {pcap}", "WARN")
        return None

    if not os.path.exists(hash_file) or os.path.getsize(hash_file) == 0:
        log(f"Skipping (empty hash file): {pcap}", "WARN")
        return None

    log(f"Valid hash extracted: {hash_file}", "SUCCESS")
    return hash_file


# -----------------------------
# Extract ESSID
# -----------------------------
def extract_essid_from_22000(line):
    try:
        parts = line.strip().split("*")
        return parts[5]
    except Exception:
        return None


# -----------------------------
# Deduplicate
# -----------------------------
def deduplicate_hashes(hash_files, combined_file):
    seen_essids = set()
    kept = 0
    skipped = 0

    with open(combined_file, "w") as outfile:
        for hf in hash_files:
            with open(hf, "r") as infile:
                for line in infile:
                    essid = extract_essid_from_22000(line)

                    if not essid:
                        continue

                    if essid in seen_essids:
                        skipped += 1
                        continue

                    seen_essids.add(essid)
                    outfile.write(line)
                    kept += 1

    log(f"Deduplicated hashes: kept={kept}, skipped={skipped}", "INFO")
    return combined_file

def build_session_name(mode, args):
    if mode in ("wordlist", "hybrid", "hybrid_reverse"):
        wordlist = os.path.basename(args["wordlist"])

        # replace troublesome characters
        wordlist = (
            wordlist
            .replace(".", "_")
            .replace(" ", "_")
        )

        return f"hashkitty_{mode}_{wordlist}"

    return f"hashkitty_{mode}"


# -----------------------------
# Run Hashcat
# -----------------------------
def run_hashcat(hash_file, mode, args):
    session_name = build_session_name(mode, args)
    potfile = f"{session_name}.potfile"

    log(f"Running hashcat on {hash_file}", "STEP")
    log(f"Session name: {session_name}", "INFO")
    log("Press 's' for status, 'q' to quit", "INFO")

    if mode == "wordlist":
        cmd = [
            "hashcat",
            "-m", "22000",
            hash_file,
            args["wordlist"],
            "--potfile-path", potfile,
            "--session", session_name
        ]

    elif mode == "mask":
        cmd = [
            "hashcat",
            "-m", "22000",
            "-a", "3",
            hash_file,
            args["mask"],
            "--potfile-path", potfile,
            "--session", session_name
        ]

    elif mode == "hybrid":
        cmd = [
            "hashcat",
            "-m", "22000",
            "-a", "6",
            hash_file,
            args["wordlist"],
            args["mask"],
            "--potfile-path", potfile,
            "--session", session_name
        ]

    elif mode == "hybrid_reverse":
        cmd = [
            "hashcat",
            "-m", "22000",
            "-a", "7",
            hash_file,
            args["mask"],
            args["wordlist"],
            "--potfile-path", potfile,
            "--session", session_name
        ]

    else:
        log("Invalid mode in run_hashcat()", "ERROR")
        return []

    try:
        exit_code = run_interactive_command(cmd)

        if exit_code == 255:
            log("Session saved. Use restore to continue later.", "INFO")
            return []

        elif exit_code != 0:
            log(f"Hashcat exited with code {exit_code}", "ERROR")
            return []
    except subprocess.CalledProcessError as e:
        log(f"Hashcat exited with code {e.returncode}", "ERROR")

        if e.stderr:
            log(e.stderr.strip(), "ERROR")

        return []

    result = run_command(
        [
            "hashcat",
            "-m", "22000",
            hash_file,
            "--show",
            "--potfile-path", potfile,
            "--session", session_name
        ]
    )

    if result is None:
        return []

    if result.stdout.strip():
        return result.stdout.strip().splitlines()

    return []

    

# -----------------------------
# Parse Results
# -----------------------------
def parse_hashcat_output(lines):
    results = []

    for line in lines:
        try:
            parts = line.split(":")
            password = parts[-1]
            essid = parts[-2]
            results.append((essid, password))
        except Exception:
            continue

    return results


# -----------------------------
# Main
# -----------------------------
def main():
    if len(sys.argv) < 2:
        print_usage()
        sys.exit(0)

    if sys.argv[1] == "restore":
        if len(sys.argv) < 3:
            print("Usage:")
            print("    ./hashkitty restore <session_name>")
            sys.exit(1)

        session_name = sys.argv[2]

        log(f"Restoring session {session_name}", "STEP")

        result = subprocess.run(
            [
                "hashcat",
                "--restore",
                "--session",
                session_name
            ]
        )

        if result.returncode == 2:
            log("Session saved.", "INFO")

        elif result.returncode != 0:
            log(f"Hashcat exited with code {result.returncode}", "ERROR")

        sys.exit(0)

    mode = sys.argv[1]
    args = {}

    if mode == "wordlist":
        if len(sys.argv) < 3:
            print_usage()
            sys.exit(1)
        args["wordlist"] = sys.argv[2]

    elif mode == "mask":
        if len(sys.argv) < 3:
            print_usage()
            sys.exit(1)
        args["mask"] = sys.argv[2]

    elif mode == "hybrid":
        if len(sys.argv) < 4:
            print_usage()
            sys.exit(1)
        args["wordlist"] = sys.argv[2]
        args["mask"] = sys.argv[3]

    elif mode == "hybrid_reverse":
        if len(sys.argv) < 4:
            print_usage()
            sys.exit(1)
        args["wordlist"] = sys.argv[2]
        args["mask"] = sys.argv[3]

    else:
        print_usage()
        sys.exit(1)

    pcaps = [f for f in os.listdir(".") if f.endswith(".pcap")]

    if not pcaps:
        log("No pcap files found", "ERROR")
        sys.exit(1)

    log(f"Found {len(pcaps)} pcap files")

    hash_files = []

    for i, pcap in enumerate(pcaps, 1):
        log(f"[{i}/{len(pcaps)}] Processing {pcap}")

        hf = convert_to_hash(pcap)
        if hf:
            hash_files.append(hf)

    if not hash_files:
        print_banner("NO VALID HANDSHAKES FOUND", success=False)
        sys.exit(0)

    combined_file = "combined.22000"
    deduplicate_hashes(hash_files, combined_file)

    # for hf in hash_files:
    #     if os.path.exists(hf):
    #         os.remove(hf)

    results = run_hashcat(combined_file, mode, args)

    parsed = parse_hashcat_output(results)

    if parsed:
        print_banner(f"CRACKED {len(parsed)} NETWORK(S)!", success=True)
        for essid, password in parsed:
            log(f"{essid} → {password}", "CRITICAL")
    else:
        print_banner("NO PASSWORDS FOUND", success=False)

    log("Done!")


if __name__ == "__main__":
    main()